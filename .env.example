# Токен сообщества ВКонтакте (Управление -> Работа с API -> Ключи доступа)
VK_TOKEN=токен_сообщества_вк

# Токен Telegram-бота от @BotFather
TG_BOT_TOKEN=токен_телеграм_бота

# Твой Telegram user id (узнать у @userinfobot)
TG_OWNER_ID=твой_telegram_id

# Необязательно: путь к файлу БД (в docker переопределяется на /data/bridge.db)
# DB_PATH=bridge.db
